<IfModule mod_headers.c>
    # HTML, XML, and JSON files (always fetch fresh)
    <FilesMatch "\.(html|htm|xml|json)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # Unhashed CSS and JavaScript (revalidate with server before using)
    # Note: Subdirectories with hashed assets (like _astro/) override this.
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>

    # General Static Assets (Images, Web Manifests, and Fonts)
    <FilesMatch "\.(ico|gif|jpe?g|png|svg|webp|woff2?|ttf|otf|eot|webmanifest)$">
        Header set Cache-Control "public, max-age=604800, must-revalidate"
    </FilesMatch>
</IfModule>

ErrorDocument 404 /404.html
