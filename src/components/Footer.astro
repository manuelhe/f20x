---
import siteConfig from '~/site.config'
import SocialLinks from '~/components/SocialLinks.astro'
---

<footer
  class="mt-auto pt-9 md:pt-11 grow-0 flex flex-col gap-6 items-center justify-between max-w-full text-foreground/80"
>
  {siteConfig.socialLinks && <SocialLinks socialLinks={siteConfig.socialLinks} />}
  <div class="flex flex-col md:flex-row flex-wrap flex-1 items-center justify-center">
    <span class="my-1">
      {siteConfig.author} © 2025
    </span>
    <span class="mx-5 hidden md:block"> :: </span>
    <span class="my-1">
      <a href="https://fractalsoftware.com" target="_blank" rel="noopener noreferrer" class="fractal-link">
        <!-- Neon pulse dot -->
        <span class="neon-pulse-dot"></span>
        
        <span class="engineered-text">Engineered by</span>
        
        <!-- Geometric Fractal logo -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 202.22 202.22" class="fractal-logo" aria-hidden="true">
          <path fill="currentColor" d="m56.47 134.56 31.58-39.4h92.08l-33.87 44.97h-49v29.37h68.87l-33.48 44.72-35.43-.06.03 27.5-40.78 35.8zm31.5 106.47-9.24-4.35-8.76 20.27zm-14.92-7.83-9.85-9.7.03 32.24zm17.6-12.14-7.84 9.5 7.81 4.35zM73.3 204.2l-8.83 11.48 9.1 8.06zm15.71 7.77-8.83-6.98.2 17.55zm25.07-19.73-11.84 15.37h21.99zm-24.43-18.78-26.43-28.83-.03 61.16Zm49.1 21.58h-14.78l6.94 10.18zm-48.14-11.86-10.4 12.91 10.37 8.42zm18.38 4.1-11.72-7.86-.03 23.72zm29.27.82-6.4-9.6-7.1 9.56zM153 176.14l-14.51-.03 6.71 9.99zm-27.65-.06-20.89.02 13.54 9.73zm-34.72-31.56-9.3 9.63 9.31 10.32zm-17.03-20.5-9.37 11.74 9.28 9.92zm15.72 12.46-8.87-10.6-.11 19.28zm48.4-3.22-16.02-24.8-2.74 12.01-15.62 12.98zm-29.37-12.74-23.6-.01 9.64 11.45zm44.26-.13-15.42.01 7.38 10.74zm-36.28-18.35h-18.4l15.22 13.79zm35.85 11.85-6.48-9.46-7.54 9.45zm-62.5-10.2-8.12 10.16 19.15.04zm76.8-1.65H152.3l6.78 10.05zm-27.4 0h-13.04l5.72 9.52z" transform="translate(-17.14 -85.2)"/>
        </svg>
        
        <span class="brand-name">FractalSoftware</span>
      </a>
    </span>
  </div>
</footer>

<style>
  .fractal-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(15, 23, 42, 0.65);
    border: 1px solid rgba(16, 185, 129, 0.15);
    border-radius: 9999px;
    text-decoration: none;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
    font-size: 11px;
    font-weight: 600;
    color: #d3d3d3;
    box-shadow: 0 4px 20px -2px rgba(16, 185, 129, 0.05);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .fractal-link:hover {
    color: #10b981;
    border: 1px solid rgba(16, 185, 129, 0.4);
    box-shadow: 0 0 16px rgba(16, 185, 129, 0.2);
    transform: translateY(-1px);
  }

  .neon-pulse-dot {
    width: 6px;
    height: 6px;
    background-color: #10b981;
    border-radius: 50%;
    box-shadow: 0 0 8px #10b981;
  }

  .fractal-logo {
    width: 14px;
    height: 14px;
    color: #10b981;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .fractal-link:hover .fractal-logo {
    transform: scale(1.2);
  }

  .brand-name {
    color: #ffffff;
    font-weight: 700;
    letter-spacing: 0.5px;
  }
</style>
